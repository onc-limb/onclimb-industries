{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "f=\"$CLAUDE_PROJECT_DIR/.claude/hooks/block-study-writes.py\"; [ -f \"$f\" ] && exec python3 \"$f\" || exit 0"
          }
        ]
      }
    ]
  }
}
