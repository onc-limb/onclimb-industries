# Generated documents produced by skills (kept out of version control)
/out/

# Pipeline execution logs emitted at the repo root
# NOTE: skill-local logs (.claude/skills/*/logs/) are tracked on purpose
/logs/

# Voice/source archives generated at the repo root
/*-omni-archive.md

# worklog: 収集した作業ログ・生成物（機密を含みうるため追跡しない）
/worklog-data/

# knowledge-base: 生成した Obsidian vault（蓄積場所。別 private リポジトリで管理する前提）
/knowledge-base/

# giziroku: 入力の文字起こしと生成議事録（機密を含みうるため追跡しない）
/giziroku/

# report-record / report-deck: 依頼者向け報告の一次記録と生成スライド（機密を含みうるため追跡しない）
/report-record/
/report-deck/

# macOS
.DS_Store
